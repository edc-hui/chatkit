{
  "name": "@kweaver-ai/chatkit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./provider-dip": {
      "types": "./dist/provider-dip.d.ts",
      "import": "./dist/provider-dip.js"
    },
    "./provider-coze": {
      "types": "./dist/provider-coze.d.ts",
      "import": "./dist/provider-coze.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js"
    },
    "./shared": {
      "types": "./dist/shared.d.ts",
      "import": "./dist/shared.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@kweaver-ai/chatkit-core": "0.0.0",
    "@kweaver-ai/chatkit-provider-coze": "0.0.0",
    "@kweaver-ai/chatkit-provider-dip": "0.0.0",
    "@kweaver-ai/chatkit-react": "0.0.0",
    "@kweaver-ai/chatkit-shared": "0.0.0",
    "@kweaver-ai/chatkit-vue": "0.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  }
}
